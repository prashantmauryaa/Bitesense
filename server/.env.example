# Copy this file to .env and fill in real values.

# MongoDB connection string. Local example:
#   MONGODB_URI=mongodb://127.0.0.1:27017/bitesense
# Atlas example:
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bitesense
MONGODB_URI=mongodb://127.0.0.1:27017/bitesense

# Secret used to sign auth tokens (HMAC-SHA256). Use a long random string in production.
BS_SECRET=bitesense-dev-secret-change-in-production

# Port the Express API listens on.
PORT=3000

# Origin(s) the API should accept requests from (comma-separated). In dev this is
# your Vite client, e.g. http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
